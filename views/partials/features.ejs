<section id="features" class="sec-zoom">
  <div class="wrap">
    <div class="sec-header rv">
      <span class="chip chip-amber chip-dot" style="margin-bottom:16px">Funcionalidades</span>
      <h2 class="ttl hd-zoom" style="margin-bottom:12px">Aumenta tu <em style="font-style:normal;color:var(--amber)">productividad</em></h2>
      <p class="lead rv">Más de 12 herramientas de IA integradas para multiplicar tu productividad.</p>
    </div>

    <div class="feat-grid stagger-grid">
      <% features.forEach((f, i) => { %>
      <div class="feat-card <%= i % 2 === 0 ? 'rv-l' : 'rv-r' %> d<%= (i % 4) + 1 %>">
        <div class="feat-icon"><i data-lucide="<%= f.icon %>"></i></div>
        <div class="feat-name"><%= f.name %></div>
        <div class="feat-desc"><%= f.desc %></div>
      </div>
      <% }) %>
    </div>
  </div>
</section>
