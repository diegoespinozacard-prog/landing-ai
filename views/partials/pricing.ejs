<section id="pricing" class="sec-zoom">
  <div class="wrap">
    <div class="pricing-header rv">
      <span class="chip chip-amber chip-dot" style="margin-bottom:16px">Precios</span>
      <h2 class="ttl hd-zoom" style="margin-bottom:0">Elige tu plan</h2>
    </div>

    <div class="pricing-grid">
      <% pricingPlans.forEach((plan, i) => { %>
      <div class="pricing-card <%= plan.popular ? 'popular' : '' %> rv d<%= i + 1 %>">
        <% if (plan.popular) { %>
        <div class="popular-badge"><i data-lucide="star"></i> Más popular</div>
        <% } %>

        <div class="pc-plan"><%= plan.name %></div>

        <div class="pc-price">
          <% if (plan.suffix) { %>
          <span class="curr">$</span>
          <span class="amt"><%= plan.price %></span>
          <span class="per"><%= plan.suffix %></span>
          <% } else { %>
          <span class="amt" style="font-size:28px"><%= plan.price %></span>
          <% } %>
        </div>

        <p class="pc-desc"><%= plan.description %></p>

        <% if (plan.id === 'enterprise') { %>
        <button class="pc-cta" onclick="openEnterpriseModal()"><%= plan.cta %></button>
        <% } else { %>
        <button
          class="pc-cta"
          data-plan="<%= plan.id %>"
          data-label="<%= plan.id === 'pro' ? 'Plan Pro — $19/mes' : 'Plan Max — $49/mes' %>"
          onclick="openModal('<%= plan.id %>')">
          <%= plan.cta %>
        </button>
        <% } %>

        <div class="pc-sep"></div>
        <div class="pc-features">
          <% plan.features.forEach(f => { %>
          <div class="pcf-item"><span class="check"></span><%= f %></div>
          <% }) %>
        </div>
      </div>
      <% }) %>
    </div>

    <div class="pricing-note"><i data-lucide="lock"></i> Pago seguro · Cancela en cualquier momento · Sin cargos ocultos</div>
  </div>
</section>
