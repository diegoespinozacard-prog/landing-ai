<section id="world-real">
  <div class="wrap">
    <div class="sec-header rv">
      <span class="chip chip-amber chip-dot" style="margin-bottom:16px">Casos de uso</span>
      <h2 class="ttl" data-word-reveal="ltr">MultIA en el <em style="font-style:normal;color:var(--amber)">mundo real</em></h2>
      <p class="lead rv" style="margin-top:14px">Así es como las organizaciones transforman su operación con nuestra plataforma.</p>
    </div>

    <!-- ══ CARD 1: El motor de creación de valor ══ -->
    <div class="wr-card rv-l gsap-wr-card">
      <div class="wr-card-meta">
        <span class="chip chip-amber chip-dot">Motor de valor</span>
        <h3 class="wr-card-title">El motor de creación de valor: <em>Inteligencia, Conocimiento y Automatización</em></h3>
      </div>
      <div class="wr-motor-layout">
        <!-- Col 1: Inteligencia -->
        <div class="wr-motor-col gsap-motor-col">
          <div class="wr-motor-icon-box"><i data-lucide="shuffle"></i></div>
          <div class="wr-motor-col-name">Inteligencia Multi-LLM</div>
          <p class="wr-motor-col-desc">Cambia dinámicamente entre ChatGPT, Claude, Gemini o Grok. El modelo exacto para cada tarea, sin perder el hilo ni el contexto del proyecto.</p>
          <div class="wr-models-strip">
            <span class="wr-model-chip wr-mc-gpt">GPT</span>
            <span class="wr-model-chip wr-mc-claude">A</span>
            <span class="wr-model-chip wr-mc-gemini">✦</span>
            <span class="wr-model-chip wr-mc-grok">𝕏</span>
            <i data-lucide="arrow-right" class="wr-models-arr"></i>
          </div>
        </div>
        <!-- Col 2: Conocimiento -->
        <div class="wr-motor-col gsap-motor-col">
          <div class="wr-motor-icon-box"><i data-lucide="folder-open"></i></div>
          <div class="wr-motor-col-name">Conocimiento Organizacional</div>
          <p class="wr-motor-col-desc">Tus documentos internos, políticas y datos se transforman en Agentes de Conocimiento entrenados y listos para accionar en tiempo real.</p>
        </div>
        <!-- Col 3: Automatización -->
        <div class="wr-motor-col gsap-motor-col">
          <div class="wr-motor-icon-box"><i data-lucide="zap"></i></div>
          <div class="wr-motor-col-name">Automatización de Procesos</div>
          <p class="wr-motor-col-desc">Agentes de Automatización con flujos de trabajo inteligentes (end-to-end) que eliminan la fricción manual y reducen el margen de error a cero.</p>
        </div>
      </div>
    </div>

    <!-- ══ CARD 2: El Desafío vs La Solución ══ -->
    <div class="wr-card rv-r gsap-wr-card">
      <div class="wr-card-meta">
        <span class="chip chip-amber chip-dot">El problema resuelto</span>
        <h3 class="wr-card-title">Las empresas necesitan múltiples IAs, pero cambiar de herramienta <em>rompe el flujo de trabajo</em></h3>
      </div>
      <div class="wr-vs-layout">
        <!-- Chaos panel -->
        <div class="wr-chaos-panel gsap-chaos-panel">
          <div class="wr-panel-badge wr-badge-problem">El Desafío — Fragmentación</div>
          <div class="wr-orbit-wrap wr-chaos-orbit">
            <div class="wr-orbit-center wr-chaos-center"><i data-lucide="frown"></i></div>
            <div class="wr-orbit-node gsap-chaos-node" style="--oa:0deg">  <i data-lucide="brain"></i></div>
            <div class="wr-orbit-node gsap-chaos-node" style="--oa:60deg"> <i data-lucide="cpu"></i></div>
            <div class="wr-orbit-node gsap-chaos-node" style="--oa:120deg"><i data-lucide="bot"></i></div>
            <div class="wr-orbit-node gsap-chaos-node" style="--oa:180deg"><i data-lucide="search"></i></div>
            <div class="wr-orbit-node gsap-chaos-node" style="--oa:240deg"><i data-lucide="settings"></i></div>
            <div class="wr-orbit-node gsap-chaos-node" style="--oa:300deg"><i data-lucide="database"></i></div>
            <svg class="wr-chaos-svg" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="124" y1="100" x2="185" y2="100" stroke="rgba(239,68,68,0.35)" stroke-width="1.5" stroke-dasharray="5,4"/>
              <line x1="112" y1="121" x2="143" y2="178" stroke="rgba(239,68,68,0.35)" stroke-width="1.5" stroke-dasharray="5,4"/>
              <line x1="88"  y1="121" x2="57"  y2="178" stroke="rgba(239,68,68,0.35)" stroke-width="1.5" stroke-dasharray="5,4"/>
              <line x1="76"  y1="100" x2="15"  y2="100" stroke="rgba(239,68,68,0.35)" stroke-width="1.5" stroke-dasharray="5,4"/>
              <line x1="88"  y1="79"  x2="57"  y2="22"  stroke="rgba(239,68,68,0.35)" stroke-width="1.5" stroke-dasharray="5,4"/>
              <line x1="112" y1="79"  x2="143" y2="22"  stroke="rgba(239,68,68,0.35)" stroke-width="1.5" stroke-dasharray="5,4"/>
            </svg>
          </div>
          <div class="wr-pain-chips">
            <span>Fricción operativa</span>
            <span>Pérdida de contexto</span>
            <span>Datos aislados</span>
          </div>
        </div>
        <!-- Arrow -->
        <div class="wr-vs-arrow gsap-vs-arrow">
          <i data-lucide="arrow-right" class="wr-vs-arrow-icon"></i>
        </div>
        <!-- Hub panel -->
        <div class="wr-hub-panel gsap-hub-panel">
          <div class="wr-panel-badge wr-badge-solution">La Solución — Unificación Multimodal</div>
          <div class="wr-orbit-wrap wr-hub-orbit">
            <div class="wr-orbit-center wr-hub-center gsap-hub-center"><span>MultIA</span></div>
            <div class="wr-hub-node gsap-hub-spoke" style="--oa:0deg">  <i data-lucide="file-text"></i></div>
            <div class="wr-hub-node gsap-hub-spoke" style="--oa:72deg"> <i data-lucide="image"></i></div>
            <div class="wr-hub-node gsap-hub-spoke" style="--oa:144deg"><i data-lucide="video"></i></div>
            <div class="wr-hub-node gsap-hub-spoke" style="--oa:216deg"><i data-lucide="code-2"></i></div>
            <div class="wr-hub-node gsap-hub-spoke" style="--oa:288deg"><i data-lucide="bar-chart-2"></i></div>
            <svg class="wr-hub-svg" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- 0°   right       start=circle-edge  end=left-face  -->
              <line x1="124" y1="100" x2="162" y2="100" stroke="rgba(245,166,35,0.5)" stroke-width="1.5"/>
              <!-- 72°  bottom-right -->
              <line x1="107" y1="123" x2="119" y2="158" stroke="rgba(245,166,35,0.5)" stroke-width="1.5"/>
              <!-- 144° bottom-left  -->
              <line x1="81"  y1="114" x2="53"  y2="134" stroke="rgba(245,166,35,0.5)" stroke-width="1.5"/>
              <!-- 216° top-left     -->
              <line x1="81"  y1="86"  x2="53"  y2="66"  stroke="rgba(245,166,35,0.5)" stroke-width="1.5"/>
              <!-- 288° top-right    -->
              <line x1="107" y1="77"  x2="119" y2="42"  stroke="rgba(245,166,35,0.5)" stroke-width="1.5"/>
            </svg>
          </div>
          <p class="wr-hub-footer">MultIA conecta los modelos líderes mundiales en un único flujo colaborativo multimodal en tu mismo entorno.</p>
        </div>
      </div>
    </div>

    <!-- ══ CARD 3: Madurez corporativa (Stairs) ══ -->
    <div class="wr-card rv-l gsap-wr-card">
      <div class="wr-card-meta">
        <span class="chip chip-amber chip-dot">Ruta de adopción</span>
        <h3 class="wr-card-title">Un acompañamiento estratégico para <em>cada etapa de madurez corporativa</em></h3>
      </div>
      <div class="wr-stairs-layout">
        <div class="wr-stair-item gsap-stair" data-stair="1" style="--sc:#60a5fa;--sbg:rgba(96,165,250,0.08)">
          <div class="wr-stair-body">
            <div class="wr-stair-icon"><i data-lucide="cloud"></i></div>
            <div class="wr-stair-num">01</div>
            <div class="wr-stair-name">Deploy <span>Adopción Inmediata</span></div>
            <p class="wr-stair-desc">Plataforma Multi-LLM unificada. Las empresas inician su adopción eliminando suscripciones aisladas.</p>
          </div>
          <div class="wr-stair-kpi"><span data-count="+60%" data-count-from="+0%">+0%</span><span>eficiencia operativa</span></div>
        </div>
        <div class="wr-stair-item gsap-stair" data-stair="2" style="--sc:#34d399;--sbg:rgba(52,211,153,0.08)">
          <div class="wr-stair-body">
            <div class="wr-stair-icon"><i data-lucide="cpu"></i></div>
            <div class="wr-stair-num">02</div>
            <div class="wr-stair-name">Reshape <span>Transformación Interna</span></div>
            <p class="wr-stair-desc">Despliegue de Agentes de Conocimiento en áreas clave (RRHH, Legal, Finanzas).</p>
          </div>
          <div class="wr-stair-kpi"><span data-count="&lt;30s" data-count-from="&lt;90s">&lt;90s</span><span>tiempo de respuesta</span></div>
        </div>
        <div class="wr-stair-item gsap-stair" data-stair="3" style="--sc:var(--amber);--sbg:rgba(245,166,35,0.08)">
          <div class="wr-stair-body">
            <div class="wr-stair-icon"><i data-lucide="zap"></i></div>
            <div class="wr-stair-num">03</div>
            <div class="wr-stair-name">Invent <span>Automatización Total</span></div>
            <p class="wr-stair-desc">Agentes autónomos que ejecutan integraciones y flujos complejos sin intervención humana.</p>
          </div>
          <div class="wr-stair-kpi"><span data-count="80%" data-count-from="0%">0%</span><span>reducción trabajo manual</span></div>
        </div>
      </div>
      <div class="wr-stairs-footer gsap-stairs-footer">
        <div class="wr-stairs-line"></div>
        <span>Madurez de IA en la empresa</span>
        <i data-lucide="arrow-right"></i>
      </div>
    </div>

    <!-- ══ CARD 4: Privacidad Zero Trust ══ -->
    <div class="wr-card rv-r gsap-wr-card">
      <div class="wr-card-meta">
        <span class="chip chip-amber chip-dot">Seguridad</span>
        <h3 class="wr-card-title">Privacidad absoluta por diseño: <em>Innovación sin concesiones bajo el modelo Zero Trust</em></h3>
      </div>
      <div class="wr-vault-layout">
        <!-- Left boxes -->
        <div class="wr-vault-col">
          <div class="wr-vbox gsap-vault-box">
            <div class="wr-vbox-icon"><i data-lucide="lock"></i></div>
            <div class="wr-vbox-name">Bóveda Digital Privada</div>
            <p class="wr-vbox-desc">Tus datos críticos residen en un servidor de uso exclusivo, aislado de la red pública.</p>
          </div>
          <div class="wr-vbox gsap-vault-box">
            <div class="wr-vbox-icon"><i data-lucide="ban"></i></div>
            <div class="wr-vbox-name">Cero Riesgo de Entrenamiento</div>
            <p class="wr-vbox-desc">La información corporativa nunca alimenta ni entrena modelos de lenguaje públicos.</p>
          </div>
        </div>
        <!-- Center vault -->
        <div class="wr-vault-center gsap-vault-center">
          <div class="wr-vault-3d">
            <div class="wr-vault-face">
              <i data-lucide="network" class="wr-vault-face-icon"></i>
              <div class="wr-vault-dial"></div>
            </div>
            <div class="wr-vault-shadow-box"></div>
          </div>
          <div class="wr-vault-glow"></div>
          <div class="wr-vault-beam gsap-beam"></div>
          <div class="wr-vault-models gsap-vault-models">
            <div class="wr-vault-cloud"><i data-lucide="cloud"></i><span>OpenAI</span></div>
            <div class="wr-vault-cloud"><i data-lucide="cloud"></i><span>Gemini</span></div>
            <div class="wr-vault-cloud"><i data-lucide="cloud"></i><span>Modelos Públicos</span></div>
          </div>
          <div class="wr-vault-badges gsap-vault-badges">
            <div class="wr-vault-badge"><i data-lucide="shield-check"></i><span>Filtro Zero-Risk</span></div>
            <div class="wr-vault-badge"><i data-lucide="server"></i><span>Servidor de Inferencia</span></div>
          </div>
        </div>
        <!-- Right boxes -->
        <div class="wr-vault-col">
          <div class="wr-vbox gsap-vault-box">
            <div class="wr-vbox-icon"><i data-lucide="shield"></i></div>
            <div class="wr-vbox-name">Descontextualización Inteligente</div>
            <p class="wr-vbox-desc">La IA externa solo recibe fragmentos aislados, protegiendo el contexto completo de tus archivos.</p>
          </div>
          <div class="wr-vbox gsap-vault-box">
            <div class="wr-vbox-icon"><i data-lucide="git-branch"></i></div>
            <div class="wr-vbox-name">Gobernanza y Trazabilidad</div>
            <p class="wr-vbox-desc">Control granular de accesos por proyecto y registros inmutables para cumplimiento normativo estricto.</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
