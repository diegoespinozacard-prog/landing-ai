<div class="modal-overlay" id="modal">
  <div class="modal-box pay-modal">
    <button class="modal-close" onclick="closeModal()">×</button>

    <!-- Default form state -->
    <div id="lead-form-state">
      <h2>Solicitar acceso a <span>MultIA</span></h2>
      <span class="chip chip-amber" style="margin-bottom:14px;font-size:9px;line-height:1.3;white-space:normal;height:auto;padding:3px 8px;text-transform:none;letter-spacing:0;border-radius:5px">
        Válido por solo un mes para miembros de la FEPCMAC
      </span>
      <p style="font-size:13px;color:var(--ink3);margin-bottom:20px;line-height:1.6">Completa tus datos y un asesor se pondrá en contacto contigo.</p>

      <div class="pay-row">
        <div>
          <div class="pay-label">Nombre *</div>
          <input class="pay-field" id="lead-nombre" type="text" placeholder="Juan">
        </div>
        <div>
          <div class="pay-label">Apellido *</div>
          <input class="pay-field" id="lead-apellido" type="text" placeholder="García">
        </div>
      </div>
      <div class="pay-full">
        <div class="pay-label">Teléfono *</div>
        <div class="phone-wrap">
          <div class="phone-country" id="phone-country-btn" onclick="toggleCountryDrop()">
            <span id="phone-flag">🇵🇪</span>
            <span id="phone-code">+51</span>
            <i data-lucide="chevron-down" class="phone-chevron"></i>
          </div>
          <input class="pay-field phone-number-field" id="lead-telefono" type="tel" placeholder="959 950 520">
          <div class="country-drop" id="country-drop">
            <input class="country-search" id="country-search" type="text" placeholder="Buscar país…" oninput="filterCountries(this.value)">
            <ul id="country-list"></ul>
          </div>
        </div>
      </div>
      <div class="pay-full">
        <div class="pay-label">Empresa *</div>
        <input class="pay-field" id="lead-empresa" type="text" placeholder="Acme Corp">
      </div>
      <div class="pay-full">
        <div class="pay-label">Cargo *</div>
        <input class="pay-field" id="lead-cargo" type="text" placeholder="Gerente de Operaciones">
      </div>
      <div class="pay-full">
        <div class="pay-label">Correo corporativo *</div>
        <input class="pay-field" id="lead-email" type="email" placeholder="juan@empresa.com">
      </div>

      <!-- Consentimientos -->
      <div class="consent-section">
        <div class="consent-title">CONSENTIMIENTOS</div>

        <label class="consent-item">
          <input type="checkbox" id="consent-terms" class="consent-check">
          <span class="consent-box"></span>
          <span class="consent-text">He leído y acepto los <a href="/legal/terminos" target="_blank" class="consent-link">Términos de Uso</a> y la <a href="/legal/privacidad" target="_blank" class="consent-link">Política de Privacidad</a>. <span class="consent-req">*</span></span>
        </label>

        <label class="consent-item">
          <input type="checkbox" id="consent-marketing" class="consent-check">
          <span class="consent-box"></span>
          <span class="consent-text">Acepto recibir comunicaciones sobre novedades y ofertas. <span class="consent-req">*</span></span>
        </label>

        <p class="consent-footer">* <strong>Obligatorio.</strong> Tus datos se usan únicamente para gestionar tu cuenta. Puedes ejercer tus derechos de acceso, rectificación y cancelación escribiendo a <a href="mailto:soporteventas@synopsis.ws" class="consent-link">soporteventas@synopsis.ws</a></p>
      </div>

      <div id="lead-error" style="display:none;font-size:12px;color:#ef4444;margin-bottom:10px;padding:8px 12px;background:rgba(239,68,68,0.08);border-radius:var(--r);border:1px solid rgba(239,68,68,0.2)"></div>

      <button class="btn btn-amber" id="lead-submit-btn"
        style="width:100%;padding:14px;font-size:15px;border-radius:var(--r2);margin-top:4px"
        onclick="submitLead()">
        Solicitar acceso →
      </button>
      <div class="pay-secure"><i data-lucide="shield-check"></i> Tus datos están protegidos y no serán compartidos</div>
    </div>

    <!-- Success state -->
    <div id="lead-success-state" style="display:none;text-align:center;padding:20px 0">
      <div class="lead-success-icon"><i data-lucide="check-circle"></i></div>
      <h2 style="margin:16px 0 8px">¡Solicitud enviada!</h2>
      <p style="font-size:14px;color:var(--ink3);line-height:1.7;max-width:300px;margin:0 auto 24px">
        Recibimos tu información. Un asesor de MultIA se pondrá en contacto contigo en los próximos días.
      </p>
      <button class="btn btn-amber" onclick="closeModal()" style="padding:12px 32px;border-radius:var(--r2)">Cerrar</button>
    </div>
  </div>
</div>

<script>
function submitLead() {
  var code = document.getElementById('phone-code').textContent.trim();
  var fields = {
    nombre:      document.getElementById('lead-nombre').value.trim(),
    apellido:    document.getElementById('lead-apellido').value.trim(),
    telefono:    code + ' ' + document.getElementById('lead-telefono').value.trim(),
    empresa:     document.getElementById('lead-empresa').value.trim(),
    cargo:       document.getElementById('lead-cargo').value.trim(),
    email:       document.getElementById('lead-email').value.trim(),
    terminos:    document.getElementById('consent-terms').checked ? 'Sí' : 'No',
    marketing:   document.getElementById('consent-marketing').checked ? 'Sí' : 'No'
  };

  var errEl = document.getElementById('lead-error');
  var labels = { nombre:'Nombre', apellido:'Apellido', telefono:'Teléfono', empresa:'Empresa', cargo:'Cargo', email:'Correo corporativo' };
  for (var k of Object.keys(labels)) {
    if (!fields[k] || fields[k] === code.trim()) {
      errEl.textContent = 'El campo "' + labels[k] + '" es obligatorio.';
      errEl.style.display = 'block';
      return;
    }
  }
  if (!document.getElementById('consent-terms').checked) {
    errEl.textContent = 'Debes aceptar los Términos de Uso y la Política de Privacidad para continuar.';
    errEl.style.display = 'block';
    return;
  }
  if (!document.getElementById('consent-marketing').checked) {
    errEl.textContent = 'Debes aceptar recibir comunicaciones sobre novedades y ofertas.';
    errEl.style.display = 'block';
    return;
  }
  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(fields.email)) {
    errEl.textContent = 'Ingresa un correo electrónico válido.';
    errEl.style.display = 'block';
    return;
  }
  var PERSONAL_DOMAINS = [
    'gmail.com','googlemail.com','hotmail.com','hotmail.es','hotmail.co',
    'outlook.com','outlook.es','live.com','live.cl','live.com.ar','live.com.mx',
    'yahoo.com','yahoo.es','yahoo.com.ar','yahoo.com.mx','yahoo.co',
    'icloud.com','me.com','mac.com',
    'aol.com','msn.com','protonmail.com','proton.me','tutanota.com',
    'yandex.com','yandex.ru','mail.com','zoho.com','gmx.com','inbox.com',
    'terra.com','terra.com.br','bol.com.br','uol.com.br',
    'qq.com','163.com','126.com'
  ];
  var emailDomain = fields.email.split('@')[1].toLowerCase();
  if (PERSONAL_DOMAINS.some(function(d){ return emailDomain === d || emailDomain.endsWith('.'+d); })) {
    errEl.textContent = 'Por favor usa tu correo corporativo, no un correo personal (' + emailDomain + ').';
    errEl.style.display = 'block';
    return;
  }
  errEl.style.display = 'none';

  var btn = document.getElementById('lead-submit-btn');
  btn.disabled = true;
  btn.textContent = 'Enviando…';

  fetch('/api/leads', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(fields)
  })
  .then(function(r){ return r.json(); })
  .then(function(data){
    if (data.ok) {
      document.getElementById('lead-form-state').style.display = 'none';
      document.getElementById('lead-success-state').style.display = 'block';
      if (typeof lucide !== 'undefined') lucide.createIcons();
    } else {
      errEl.textContent = 'Error al enviar. Intenta de nuevo.';
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Solicitar acceso →';
    }
  })
  .catch(function(){
    errEl.textContent = 'Error de conexión. Intenta de nuevo.';
    errEl.style.display = 'block';
    btn.disabled = false;
    btn.textContent = 'Solicitar acceso →';
  });
}

/* ── Country picker ── */
// fmt: array of digit-group sizes, e.g. [3,3,3] → "999 999 999"
// placeholder shown in input field
var COUNTRIES = [
  {f:'🇦🇷',n:'Argentina',     c:'+54',  fmt:[2,4,4],  ph:'11 2345 6789'},
  {f:'🇧🇴',n:'Bolivia',       c:'+591', fmt:[8],      ph:'71234567'},
  {f:'🇧🇷',n:'Brasil',        c:'+55',  fmt:[2,5,4],  ph:'11 91234 5678'},
  {f:'🇨🇱',n:'Chile',         c:'+56',  fmt:[1,4,4],  ph:'9 1234 5678'},
  {f:'🇨🇴',n:'Colombia',      c:'+57',  fmt:[3,3,4],  ph:'300 123 4567'},
  {f:'🇨🇷',n:'Costa Rica',    c:'+506', fmt:[4,4],    ph:'8812 3456'},
  {f:'🇨🇺',n:'Cuba',          c:'+53',  fmt:[4,4],    ph:'5123 4567'},
  {f:'🇩🇴',n:'Rep. Dominicana',c:'+1',  fmt:[3,3,4],  ph:'809 123 4567'},
  {f:'🇪🇨',n:'Ecuador',       c:'+593', fmt:[2,3,4],  ph:'99 123 4567'},
  {f:'🇸🇻',n:'El Salvador',   c:'+503', fmt:[4,4],    ph:'7012 3456'},
  {f:'🇪🇸',n:'España',        c:'+34',  fmt:[3,3,3],  ph:'612 345 678'},
  {f:'🇺🇸',n:'Estados Unidos', c:'+1',  fmt:[3,3,4],  ph:'212 555 1234'},
  {f:'🇬🇹',n:'Guatemala',     c:'+502', fmt:[4,4],    ph:'5123 4567'},
  {f:'🇭🇳',n:'Honduras',      c:'+504', fmt:[4,4],    ph:'9123 4567'},
  {f:'🇲🇽',n:'México',        c:'+52',  fmt:[2,4,4],  ph:'55 1234 5678'},
  {f:'🇳🇮',n:'Nicaragua',     c:'+505', fmt:[4,4],    ph:'8123 4567'},
  {f:'🇵🇦',n:'Panamá',        c:'+507', fmt:[4,4],    ph:'6123 4567'},
  {f:'🇵🇾',n:'Paraguay',      c:'+595', fmt:[3,3,3],  ph:'961 123 456'},
  {f:'🇵🇪',n:'Perú',          c:'+51',  fmt:[3,3,3],  ph:'959 950 520'},
  {f:'🇵🇷',n:'Puerto Rico',   c:'+1',   fmt:[3,3,4],  ph:'787 555 1234'},
  {f:'🇺🇾',n:'Uruguay',       c:'+598', fmt:[2,3,3],  ph:'94 123 456'},
  {f:'🇻🇪',n:'Venezuela',     c:'+58',  fmt:[3,3,4],  ph:'412 123 4567'},
  {f:'🇬🇧',n:'Reino Unido',   c:'+44',  fmt:[4,3,4],  ph:'7911 123 456'},
  {f:'🇨🇦',n:'Canadá',        c:'+1',   fmt:[3,3,4],  ph:'416 555 1234'},
  {f:'🇩🇪',n:'Alemania',      c:'+49',  fmt:[3,4,4],  ph:'152 1234 5678'},
  {f:'🇫🇷',n:'Francia',       c:'+33',  fmt:[1,2,2,2,2],ph:'6 12 34 56 78'},
  {f:'🇮🇹',n:'Italia',        c:'+39',  fmt:[3,4,4],  ph:'312 3456 789'},
  {f:'🇵🇹',n:'Portugal',      c:'+351', fmt:[3,3,3],  ph:'912 345 678'}
];

var currentFmt = [3,3,3];

function applyPhoneFmt(raw) {
  var result = '';
  var i = 0;
  for (var g = 0; g < currentFmt.length; g++) {
    var chunk = raw.substr(i, currentFmt[g]);
    if (!chunk) break;
    if (result) result += ' ';
    result += chunk;
    i += currentFmt[g];
  }
  return result;
}

function renderCountries(list) {
  var ul = document.getElementById('country-list');
  ul.innerHTML = list.map(function(c, i){
    var idx = COUNTRIES.indexOf(c);
    return '<li onclick="selectCountry(' + idx + ')">' +
      '<span class="cf">' + c.f + '</span>' +
      '<span class="cn">' + c.n + '</span>' +
      '<span class="cc">' + c.c + '</span></li>';
  }).join('');
}

function filterCountries(q) {
  renderCountries(COUNTRIES.filter(function(c){
    return c.n.toLowerCase().includes(q.toLowerCase()) || c.c.includes(q);
  }));
}

function selectCountry(idx) {
  var c = COUNTRIES[idx];
  document.getElementById('phone-flag').textContent = c.f;
  document.getElementById('phone-code').textContent = c.c;
  currentFmt = c.fmt;
  var input = document.getElementById('lead-telefono');
  input.placeholder = c.ph;
  input.value = '';
  input.focus();
  document.getElementById('country-drop').classList.remove('open');
}

function toggleCountryDrop() {
  var drop = document.getElementById('country-drop');
  drop.classList.toggle('open');
  if (drop.classList.contains('open')) {
    document.getElementById('country-search').value = '';
    renderCountries(COUNTRIES);
    setTimeout(function(){ document.getElementById('country-search').focus(); }, 50);
  }
}

document.getElementById('lead-telefono').addEventListener('input', function(){
  var raw = this.value.replace(/\D/g,'');
  var maxDigits = currentFmt.reduce(function(a,b){return a+b;},0);
  if (raw.length > maxDigits) raw = raw.substr(0, maxDigits);
  this.value = applyPhoneFmt(raw);
});

document.addEventListener('click', function(e){
  if (!e.target.closest('#phone-country-btn') && !e.target.closest('#country-drop')) {
    var d = document.getElementById('country-drop');
    if (d) d.classList.remove('open');
  }
});

// Init with Perú (default)
var _peru = COUNTRIES.find(function(c){return c.c==='+51'&&c.n==='Perú';});
if(_peru){ currentFmt=_peru.fmt; document.getElementById('lead-telefono').placeholder=_peru.ph; }
renderCountries(COUNTRIES);
</script>
